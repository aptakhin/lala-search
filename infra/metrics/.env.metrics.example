# VM metrics environment for Grafana Alloy remote_write
# Copy to .env.metrics on the remote host if you manage the stack manually.

ALLOY_IMAGE_TAG=latest

# Grafana Cloud -> Prometheus -> Send Metrics endpoint
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX-prod-YY.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=CHANGE_ME_METRICS_INSTANCE_ID
GRAFANA_CLOUD_PROMETHEUS_PASSWORD=CHANGE_ME_GRAFANA_CLOUD_API_KEY

# Labels attached to every metric sample
VM_METRICS_INSTANCE=your-vm-name
VM_METRICS_ENVIRONMENT=prod
