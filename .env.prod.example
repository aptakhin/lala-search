# LalaSearch Production Environment Configuration
# Copy this file to .env.prod and update ALL values marked CHANGE_ME
#
# IMPORTANT: You MUST change all passwords and secrets before first run!

# === Agent Configuration ===
AGENT_MODE=all
DEPLOYMENT_MODE=single_tenant
ENVIRONMENT=prod
RUST_LOG=info

# === Database Configuration (PostgreSQL) ===
# Username and password for PostgreSQL (used by both postgres container and agent)
POSTGRES_USER=lalasearch
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
DATABASE_URL=postgres://lalasearch:CHANGE_ME_GENERATE_STRONG_PASSWORD@postgres:5432/lalasearch

# === Search Engine Configuration (Meilisearch) ===
# Internal Docker hostname — do not change unless you rename the service
MEILISEARCH_HOST=meilisearch:7700

# === Crawler Configuration ===
QUEUE_POLL_INTERVAL_SECS=5
USER_AGENT=LalaSearchBot/0.1

# === S3 Storage Configuration (SeaweedFS) ===
# Internal Docker hostname — do not change unless you rename the service
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=us-east-1
S3_BUCKET=lalasearch-content
# These must match between the agent and seaweedfs-init
S3_ACCESS_KEY=CHANGE_ME_GENERATE_S3_KEY
S3_SECRET_KEY=CHANGE_ME_GENERATE_S3_SECRET
S3_COMPRESS_CONTENT=true
S3_COMPRESS_MIN_SIZE=1024

# === Authentication Configuration ===
# You need an external SMTP service for production (e.g., Mailgun, Postmark, SES)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_SMTP_USERNAME
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_TLS=true

# Email sender settings
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=LalaSearch

# Root admin email — this user can self-register and becomes Owner
# of the default tenant. Required when SMTP is configured.
LALA_ROOT_ADMIN_EMAIL=admin@yourdomain.com

# Application base URL (must point to your public frontend URL)
APP_BASE_URL=https://search.yourdomain.com

# Session and token expiry
SESSION_MAX_AGE_DAYS=365
MAGIC_LINK_EXPIRY_MINUTES=15
MAGIC_LINK_SEND_COOLDOWN_SECONDS=60
MAGIC_LINK_MAX_SEND_ATTEMPTS=5
MAGIC_LINK_SEND_WINDOW_MINUTES=15
MAGIC_LINK_PERMANENT_BLOCK_AFTER_ATTEMPTS=10
INVITATION_EXPIRY_DAYS=7
